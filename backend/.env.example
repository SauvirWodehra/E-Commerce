# Environment Variables
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sde_ecommerce

# JWT Authentication
JWT_SECRET=amazon_clone_jwt_secret_key_2026_sde_assignment

# Stripe Payment Gateway (Test Keys)
STRIPE_SECRET_KEY=sk_test_... (optional)
STRIPE_PUBLISHABLE_KEY=pk_test_... (optional)

# SMTP Email Configuration (Add your Gmail app password if you want real emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Amazon Clone <your_email@gmail.com>"
